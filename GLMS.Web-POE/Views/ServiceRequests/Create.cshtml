@model GLMS.Web_POE.Models.ServiceRequest

@{
    ViewData["Title"] = "Create New Service Request";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-8">
            <h1 class="mb-4">Create New Service Request</h1>

            <form asp-action="Create" method="post">
                <div asp-validation-summary="All" class="alert alert-danger" role="alert"></div>

                <div class="form-group mb-3">
                    <label asp-for="ContractId" class="form-label">Contract <span class="text-danger">*</span></label>
                    <select asp-for="ContractId" class="form-control" asp-items="ViewBag.ContractId" required>
                        <option value="">-- Select a Contract --</option>
                    </select>
                    <small class="form-text text-muted">Only Active or Draft contracts are available</small>
                    <span asp-validation-for="ContractId" class="text-danger small"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Description" class="form-label">Description <span class="text-danger">*</span></label>
                    <textarea asp-for="Description" class="form-control" rows="4" placeholder="Describe the service request..." required></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>

                <div class="form-group mb-4">
                    <label asp-for="AmountUsd" class="form-label">Amount (USD) <span class="text-danger">*</span></label>
                    <div class="input-group">
                        <span class="input-group-text">$</span>
                        <input asp-for="AmountUsd" type="number" step="0.01" class="form-control" placeholder="0.00" required />
                    </div>
                    <small class="form-text text-muted">Amount will be automatically converted to ZAR at current exchange rate</small>
                    <span asp-validation-for="AmountUsd" class="text-danger small"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save"></i> Create Service Request
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="fas fa-arrow-left"></i> Back to List
                    </a>
                </div>
            </form>
        </div>

        <div class="col-md-4">
            <div class="card bg-light">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Currency Information</h5>
                </div>
                <div class="card-body">
                    <p><strong>Current Exchange Rate:</strong></p>
                    <p class="h4 text-success">1 USD = ~18.50 ZAR</p>
                    <hr />
                    <p><small class="text-muted">Rates are automatically fetched from the ExchangeRate API when you submit the form.</small></p>
                    <p><small class="text-muted">The ZAR amount will be calculated and saved with your service request.</small></p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
