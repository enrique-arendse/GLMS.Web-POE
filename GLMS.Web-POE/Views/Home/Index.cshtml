@{
    ViewData["Title"] = "Dashboard";
}

<!-- Page Header -->
<div class="mb-5">
    <h1 class="mb-2">Dashboard</h1>
    <p class="text-muted">Welcome to the Global Logistics Management System. Manage your clients, contracts, and service requests all in one place.</p>
</div>

<!-- Main Cards -->
<div class="row g-4 mb-5">
    <div class="col-lg-4 col-md-6">
        <div class="card h-100 shadow-sm border-0">
            <div class="card-body d-flex flex-column">
                <div class="mb-3">
                    <i class="fa-solid fa-user fa-2x text-primary"></i>
                </div>
                <h5 class="card-title fw-bold">Clients</h5>
                <p class="card-text text-muted flex-grow-1">Create and manage client information, contact details, and service regions.</p>
                <div class="d-flex gap-2 mt-auto">
                    <a asp-controller="Clients" asp-action="Index" class="btn btn-primary btn-sm flex-grow-1">
                        <i class="fa-solid fa-list me-1"></i>View All
                    </a>
                    <a asp-controller="Clients" asp-action="Create" class="btn btn-outline-primary btn-sm flex-grow-1">
                        <i class="fa-solid fa-plus me-1"></i>New
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-4 col-md-6">
        <div class="card h-100 shadow-sm border-0">
            <div class="card-body d-flex flex-column">
                <div class="mb-3">
                    <i class="fa-solid fa-file-contract fa-2x" style="color: #20c997;"></i>
                </div>
                <h5 class="card-title fw-bold">Contracts</h5>
                <p class="card-text text-muted flex-grow-1">Create contracts, manage service levels, upload signed agreements, and track expiration dates.</p>
                <div class="d-flex gap-2 mt-auto">
                    <a asp-controller="Contracts" asp-action="Index" class="btn btn-primary btn-sm flex-grow-1">
                        <i class="fa-solid fa-list me-1"></i>View All
                    </a>
                    <a asp-controller="Contracts" asp-action="Create" class="btn btn-outline-primary btn-sm flex-grow-1">
                        <i class="fa-solid fa-plus me-1"></i>New
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-4 col-md-6">
        <div class="card h-100 shadow-sm border-0">
            <div class="card-body d-flex flex-column">
                <div class="mb-3">
                    <i class="fa-solid fa-clipboard-list fa-2x" style="color: #fd7e14;"></i>
                </div>
                <h5 class="card-title fw-bold">Service Requests</h5>
                <p class="card-text text-muted flex-grow-1">Create and track service requests with automatic currency conversion between USD and ZAR.</p>
                <div class="d-flex gap-2 mt-auto">
                    <a asp-controller="ServiceRequests" asp-action="Index" class="btn btn-primary btn-sm flex-grow-1">
                        <i class="fa-solid fa-list me-1"></i>View All
                    </a>
                    <a asp-controller="ServiceRequests" asp-action="Create" class="btn btn-outline-primary btn-sm flex-grow-1">
                        <i class="fa-solid fa-plus me-1"></i>New
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
         