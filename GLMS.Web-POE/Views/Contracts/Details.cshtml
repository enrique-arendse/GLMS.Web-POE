@model GLMS.Web_POE.Models.Contract

@{
    ViewData["Title"] = "Contract Details";
}

<div class="container mt-5">
    <h1 class="mb-4">Contract Details</h1>

    <div class="row">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Contract Information</h5>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-sm-3 fw-bold">Client:</div>
                        <div class="col-sm-9">
                            <strong>@Model.Client?.Name</strong><br/>
                            <small class="text-muted">@Model.Client?.ContactDetails</small>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-sm-3 fw-bold">Region:</div>
                        <div class="col-sm-9">@Model.Client?.Region</div>
                    </div>

                    <hr />

                    <div class="row mb-3">
                        <div class="col-sm-3 fw-bold">Start Date:</div>
                        <div class="col-sm-9">@Model.StartDate.ToString("MMMM dd, yyyy")</div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-sm-3 fw-bold">End Date:</div>
                        <div class="col-sm-9">@Model.EndDate.ToString("MMMM dd, yyyy")</div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-sm-3 fw-bold">Service Level:</div>
                        <div class="col-sm-9">@Model.ServiceLevel</div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-sm-3 fw-bold">Status:</div>
                        <div class="col-sm-9">
                            @{
                                var statusClass = Model.Status switch
                                {
                                    GLMS.Web_POE.Models.ContractStatus.Draft => "badge bg-warning",
                                    GLMS.Web_POE.Models.ContractStatus.Active => "badge bg-success",
                                    GLMS.Web_POE.Models.ContractStatus.Expired => "badge bg-danger",
                                    GLMS.Web_POE.Models.ContractStatus.OnHold => "badge bg-secondary",
                                    _ => "badge bg-light"
                                };
                            }
                            <span class="@statusClass">@Model.Status</span>
                        </div>
                    </div>

                    <hr />

                    <div class="row mb-3">
                        <div class="col-sm-3 fw-bold">Signed Agreement:</div>
                        <div class="col-sm-9">
                            @if (!string.IsNullOrEmpty(Model.SignedAgreementFileName))
                            {
                                <div class="alert alert-success mb-2" role="alert">
                                    <i class="fas fa-file-pdf"></i> <strong>@Model.SignedAgreementFileName</strong>
                                </div>
                                <a asp-action="DownloadAgreement" asp-route-id="@Model.Id" class="btn btn-sm btn-primary">
                                    <i class="fas fa-download"></i> Download Agreement
                                </a>
                            }
                            else
                            {
                                <span class="text-muted"><i class="fas fa-exclamation-triangle"></i> No agreement uploaded</span>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-4">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
            <i class="fas fa-edit"></i> Edit
        </a>
        <a asp-action="Index" class="btn btn-secondary">
            <i class="fas fa-arrow-left"></i> Back to List
        </a>
    </div>
</div>
