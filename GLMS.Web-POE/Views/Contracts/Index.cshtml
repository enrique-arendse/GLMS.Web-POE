@model IEnumerable<GLMS.Web_POE.Models.Contract>

@{
    ViewData["Title"] = "Contracts Management";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="mb-0">Contracts Management</h1>
        <a asp-action="Create" class="btn btn-primary">
            <i class="fas fa-plus"></i> Create New Contract
        </a>
    </div>

    <!-- Search and Filter Section -->
    <div class="card mb-4">
        <div class="card-header bg-light">
            <h5 class="mb-0">Search & Filter</h5>
        </div>
        <div class="card-body">
            <form asp-action="Index" method="get" class="row g-3">
                @{
                    var currentStatus = ViewData["CurrentStatus"]?.ToString();
                }
                <div class="col-md-3">
                    <label for="startDate" class="form-label">Start Date</label>
                    <input type="date" id="startDate" name="startDate" class="form-control" 
                           value="@ViewData["CurrentStartDate"]" />
                </div>
                <div class="col-md-3">
                    <label for="endDate" class="form-label">End Date</label>
                    <input type="date" id="endDate" name="endDate" class="form-control" 
                           value="@ViewData["CurrentEndDate"]" />
                </div>
                <div class="col-md-3">
                    <label for="status" class="form-label">Status</label>
                    <select id="status" name="status" class="form-control">
                        <option value="">-- All Statuses --</option>
                        <option value="0" selected="@(currentStatus == "0" ? "selected" : null)">Draft</option>
                        <option value="1" selected="@(currentStatus == "1" ? "selected" : null)">Active</option>
                        <option value="2" selected="@(currentStatus == "2" ? "selected" : null)">Expired</option>
                        <option value="3" selected="@(currentStatus == "3" ? "selected" : null)">On Hold</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">&nbsp;</label>
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-info">
                            <i class="fas fa-search"></i> Search
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Contracts Table -->
    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Client Name</th>
                        <th>Start Date</th>
                        <th>End Date</th>
                        <th>Status</th>
                        <th>Service Level</th>
                        <th>Agreement</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <strong>@Html.DisplayFor(modelItem => item.Client.Name)</strong><br/>
                                <small class="text-muted">@Html.DisplayFor(modelItem => item.Client.ContactDetails)</small>
                            </td>
                            <td>@Html.DisplayFor(modelItem => item.StartDate)</td>
                            <td>@Html.DisplayFor(modelItem => item.EndDate)</td>
                            <td>
                                @{
                                    var statusClass = item.Status switch
                                    {
                                        GLMS.Web_POE.Models.ContractStatus.Draft => "badge bg-warning",
                                        GLMS.Web_POE.Models.ContractStatus.Active => "badge bg-success",
                                        GLMS.Web_POE.Models.ContractStatus.Expired => "badge bg-danger",
                                        GLMS.Web_POE.Models.ContractStatus.OnHold => "badge bg-secondary",
                                        _ => "badge bg-light"
                                    };
                                }
                                <span class="@statusClass">@Html.DisplayFor(modelItem => item.Status)</span>
                            </td>
                            <td>@Html.DisplayFor(modelItem => item.ServiceLevel)</td>
                            <td>
                                @if (!string.IsNullOrEmpty(item.SignedAgreementFileName))
                                {
                                    <a asp-action="DownloadAgreement" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                                        <i class="fas fa-download"></i> Download
                                    </a>
                                }
                                else
                                {
                                    <span class="text-muted text-sm">No file</span>
                                }
                            </td>
                            <td>
                                <div class="btn-group btn-group-sm" role="group">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-info">
                                        <i class="fas fa-eye"></i> View
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-warning">
                                        <i class="fas fa-edit"></i> Edit
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger">
                                        <i class="fas fa-trash"></i> Delete
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info" role="alert">
            <i class="fas fa-info-circle"></i> No contracts found. <a asp-action="Create">Create a new contract</a>.
        </div>
    }
</div>
