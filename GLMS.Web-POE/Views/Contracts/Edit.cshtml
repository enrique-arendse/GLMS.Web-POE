@model GLMS.Web_POE.Models.Contract

@{
    ViewData["Title"] = "Edit Contract";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-8">
            <h1 class="mb-4">Edit Contract</h1>

            <form asp-action="Edit" enctype="multipart/form-data" method="post">
                <div asp-validation-summary="All" class="alert alert-danger" role="alert"></div>

                <input type="hidden" asp-for="Id" />

                <div class="form-group mb-3">
                    <label asp-for="ClientId" class="form-label">Client <span class="text-danger">*</span></label>
                    <select asp-for="ClientId" class="form-control" asp-items="ViewBag.ClientId" required>
                        <option value="">-- Select a Client --</option>
                    </select>
                    <span asp-validation-for="ClientId" class="text-danger small"></span>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="StartDate" class="form-label">Start Date <span class="text-danger">*</span></label>
                            <input asp-for="StartDate" type="date" class="form-control" required />
                            <span asp-validation-for="StartDate" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="EndDate" class="form-label">End Date <span class="text-danger">*</span></label>
                            <input asp-for="EndDate" type="date" class="form-control" required />
                            <span asp-validation-for="EndDate" class="text-danger small"></span>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="Status" class="form-label">Status <span class="text-danger">*</span></label>
                            <select asp-for="Status" class="form-control" required>
                                <option value="">-- Select Status --</option>
                                <option value="0">Draft</option>
                                <option value="1">Active</option>
                                <option value="2">Expired</option>
                                <option value="3">On Hold</option>
                            </select>
                            <span asp-validation-for="Status" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="ServiceLevel" class="form-label">Service Level <span class="text-danger">*</span></label>
                            <input asp-for="ServiceLevel" class="form-control" placeholder="e.g., Premium, Standard" required />
                            <span asp-validation-for="ServiceLevel" class="text-danger small"></span>
                        </div>
                    </div>
                </div>

                <div class="form-group mb-4">
                    <label for="signedAgreement" class="form-label">Signed Agreement (PDF)</label>
                    <input type="file" id="signedAgreement" name="signedAgreement" class="form-control" accept=".pdf" />
                    <small class="form-text text-muted">Only PDF files are allowed. Leave blank to keep existing agreement.</small>
                    @if (!string.IsNullOrEmpty(Model.SignedAgreementFileName))
                    {
                        <div class="alert alert-info mt-2 mb-0">
                            <i class="fas fa-file-pdf"></i> Current: <a asp-action="DownloadAgreement" asp-route-id="@Model.Id">@Model.SignedAgreementFileName</a>
                        </div>
                    }
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save"></i> Update Contract
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="fas fa-arrow-left"></i> Back to List
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
