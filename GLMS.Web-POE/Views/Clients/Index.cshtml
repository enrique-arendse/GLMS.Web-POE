@model IEnumerable<GLMS.Web_POE.Models.Client>

@{
    ViewData["Title"] = "Clients Management";
}

<div class="mb-4">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1 class="mb-1">Clients</h1>
            <p class="text-muted mb-0">Manage and organize all client information in one place.</p>
        </div>
        <a asp-action="Create" class="btn btn-primary">
            <i class="fas fa-plus me-2"></i>Create New Client
        </a>
    </div>
</div>

@if (Model.Any())
{
    <div class="table-responsive">
        <table class="table table-hover">
            <thead class="table-dark">
                <tr>
                    <th>
                        <i class="fas fa-user me-2"></i>Name
                    </th>
                    <th>
                        <i class="fas fa-phone me-2"></i>Contact Details
                    </th>
                    <th>
                        <i class="fas fa-map-marker-alt me-2"></i>Region
                    </th>
                    <th style="width: 200px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <strong>@Html.DisplayFor(modelItem => item.Name)</strong>
                        </td>
                        <td>
                            <small>@Html.DisplayFor(modelItem => item.ContactDetails)</small>
                        </td>
                        <td>
                            <span class="badge bg-info">@Html.DisplayFor(modelItem => item.Region)</span>
                        </td>
                        <td>
                            <div class="btn-group btn-group-sm" role="group">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-info" title="View">
                                    <i class="fas fa-eye"></i> View
                                </a>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-warning" title="Edit">
                                    <i class="fas fa-edit"></i> Edit
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger" title="Delete">
                                    <i class="fas fa-trash"></i> Delete
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="alert alert-info border-0" role="alert">
        <i class="fas fa-info-circle me-2"></i>
        No clients found. <a asp-action="Create" class="alert-link">Create a new client</a> to get started.
    </div>
}
